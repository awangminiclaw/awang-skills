  "award_winning_rules": {
    "oscar_best_picture": {
      "description": "奧斯卡最佳影片分鏡規則",
      "rules": [
        {
          "id": "emotional_arcs",
          "name_chinese": "情感弧線",
          "name_english": "Emotional Arcs",
