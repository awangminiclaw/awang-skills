          "application": "鏡頭非裝飾，每個畫面都有敘事功能"
        },
        {
          "id": "visual_subtext",
          "name_chinese": "視覺潛台詞",
          "name_english": "Visual Subtext",
          "rule": "畫面必須傳達潛台詞，而非僅呈現表面",
          "application": "Show, don't tell - 用畫面說故事"
        },
        {
          "id": "motivated_camera",
          "name_chinese": "動機鏡頭",
          "name_english": "Motivated Camera Movement",
          "rule": "所有運鏡皆有動機，非隨意移動",
          "application": "鏡頭跟隨角色、揭示資訊、建立張力"
        },
        {
          "id": "continuity_precision",
          "name_chinese": "連戲精準",
          "name_english": "Continuity Precision",
          "rule": "所有動作、道具、光線必須連戲",
          "application": "跨鏡頭的一致性維持"
        },
        {
          "id": "sound_design_integration",
          "name_chinese": "聲音設計整合",
          "name_english": "Sound Design Integration",
          "rule": "聲音與畫面同等重要，非後製附加",
          "application": "Dolby Atmos 全方位聲音設計"
        }
      ]
    },
